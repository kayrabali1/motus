{
  "expo": {
    "name": "Motus",
    "slug": "Motus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "motus",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "entitlements": {
        "com.apple.developer.family-controls": true,
        "com.apple.security.application-groups": [
          "group.com.kayrabali.Motus",
          "group.com.kayrabali.Motus"
        ]
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Motus needs access to the camera to validate your exercises.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.kayrabali.Motus"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.kayrabali.Motus"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "@bacons/apple-targets",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Motus needs access to your photos to let you select a custom profile avatar."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.kayrabali.Motus.shield-config",
                  "targetName": "MotusShieldConfiguration",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.kayrabali.Motus"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "com.kayrabali.Motus.shield-action",
                  "targetName": "MotusShieldAction",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.kayrabali.Motus"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "8acdf373-d3ff-45d7-967d-c3c7d69b9116"
      }
    }
  }
}
